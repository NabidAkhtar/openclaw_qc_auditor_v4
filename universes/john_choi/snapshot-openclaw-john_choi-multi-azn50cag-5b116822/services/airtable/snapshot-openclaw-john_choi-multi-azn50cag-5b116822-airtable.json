d": "tbl7d2a4e8c1f5b93", "name": "CE Credits", "base_id": "app3c6f9a2e5b8d17", "fields": [{"id": "fld8e3a1c5f7b9d20", "name": "course_name", "type": "singleLineText"}, {"id": "fld9f4b2d6a8c0e31", "name": "credit_hours", "type": "singleLineText"}, {"id": "fld0a5c3e7b9d1f42", "name": "completion_date", "type": "date"}, {"id": "fld1b6d4f8c0e2a53", "name": "provider", "type": "singleLineText"}, {"id": "fld2c7e5a9d1f3b64", "name": "certificate", "type": "singleLineText"}, {"id": "fld3d8f6b0e2a4c75", "name": "status", "type": "singleSelect"}], "views": [{"id": "viw4e9a7c1f3b5d86", "name": "Grid view", "type": "grid"}]}, {"id": "tbl5b0d3f6c8e2a49", "name": "2025 Expenses", "base_id": "app4a9c2e5b7d1f38", "fields": [{"id": "fld6c1e4a7d9f3b50", "name": "date", "type": "date"}, {"id": "fld7d2f5b8e0a4c61", "name": "vendor", "type": "singleLineText"}, {"id": "fld8e3a6c9f1b5d72", "name": "category", "type": "singleLineText"}, {"id": "fld9f4b7d0a2c6e83", "name": "amount", "type": "currency"}, {"id": "fld0a5c8e1b3d7f94", "name": "payment_method", "type": "singleLineText"}, {"id": "fld1b6d9f2c4e8a05", "name": "receipt", "type": "singleLineText"}, {"id": "fld2c7e0a3d5f9b16", "name": "notes", "type": "multilineText"}], "views": [{"id": "viw3d8f1b4e6a0c27", "name": "Grid view", "type": "grid"}]}], "records": [{"id": "rec0a3c5769ff2f06", "table_id": "tble552937bb02832", "fields": {"company_name": "Teledentistry.com", "website": "teledentistry.com", "founded": "2018", "services": "Virtual consults, second opinions, emergency triage", "pricing": "$59-99/consult (patient), $299/mo provider platform", "funding": "$7M Series A (2021)", "notes": "Biggest name in the space. Marketplace model connecting patients to dentists. Good brand recognition but reviews are mixed on consult quality. Provider side charges monthly fee for access to patient flow."}, "created_time": "2026-01-06T06:00:00Z", "modified_time": "2026-01-06T06:00:00Z"}, {"id": "recf338b7bb4eec63", "table_id": "tble552937bb02832", "fields": {"company_name": "MouthWatch TeleDent", "website": "mouthwatch.com", "founded": "2012", "services": "Intraoral camera hardware, teledentistry software platform", "pricing": "Camera $299 one-time, software $99-249/mo per provider", "funding": "~$10M total raised", "notes": "Hardware + software play. The intraoral camera is their differentiator. More B2B focused - sells to practices rather than direct to patients. Could be a platform I license rather than compete against."}, "created_time": "2026-01-06T06:15:00Z", "modified_time": "2026-01-06T06:15:00Z"}, {"id": "rec6f4c348edc9c3e", "table_id": "tble552937bb02832", "fields": {"company_name": "Dentulu", "website": "dentulu.com", "founded": "2018", "services": "Mobile dentistry + virtual consults, on-demand dental care", "pricing": "Varies by service, marketplace model", "funding": "VC-backed, undisclosed amount", "notes": "Hybrid model - sends dentists to patients AND does virtual consults. Interesting but capital intensive. Mobile dental vans are expensive. They're based in CA which means direct competition."}, "created_time": "2026-01-06T06:30:00Z", "modified_time": "2026-01-06T06:30:00Z"}, {"id": "reccd3176df4548b8", "table_id": "tble552937bb02832", "fields": {"company_name": "SmileDirectClub", "website": "smiledirectclub.com", "founded": "2014", "services": "DTC aligners with virtual monitoring", "pricing": "$1,950 treatment plan", "funding": "Was public (NASDAQ: SDC), filed Chapter 11 Nov 2023", "notes": "Cautionary tale. Huge growth, went public, then imploded. Regulatory issues in multiple states, lawsuits from dentists and patients. Shows the risk of scaling too fast in dental without enough clinical oversight."}, "created_time": "2026-01-09T07:00:00Z", "modified_time": "2026-01-09T07:00:00Z"}, {"id": "rec339b25875815bb", "table_id": "tble552937bb02832", "fields": {"company_name": "Byte", "website": "byteme.com", "founded": "2017", "services": "At-home clear aligners, virtual monitoring with HyperByte", "pricing": "$1,999 one-time treatment", "funding": "Acquired by Dentsply Sirona 2022", "notes": "Aligner focused, not general dentistry. Acquisition by Dentsply validates the virtual monitoring model. HyperByte tech is a nice differentiator. Not really a direct competitor for what I'd build."}, "created_time": "2026-01-13T06:30:00Z", "modified_time": "2026-01-13T06:30:00Z"}, {"id": "rec4e9eccc7170519", "table_id": "tble552937bb02832", "fields": {"company_name": "Overjet", "website": "overjet.com", "founded": "2018", "services": "AI dental imaging analysis for insurance and clinical use", "pricing": "Enterprise SaaS, not consumer-facing", "funding": "$53M Series B", "notes": "AI play, not direct teledentistry. Their tech could be integrated into a virtual consult platform for real-time image analysis though. Potential partner not competitor. Raised serious money which shows investor interest in dental tech."}, "created_time": "2026-02-06T07:00:00Z", "modified_time": "2026-02-06T07:00:00Z"}, {"id": "recaad42948059380", "table_id": "tble552937bb02832", "fields": {"company_name": "Bento Dental", "website": "bento.dental", "founded": "2017", "services": "Dental membership/savings plan with virtual consults included", "pricing": "$15-25/mo membership", "funding": "Seed stage", "notes": "Membership model that bundles virtual consults with dental benefits. Interesting approach to the payment side. Small team. More of a benefits play than a telehealth platform."}, "created_time": "2026-03-02T06:00:00Z", "modified_time": "2026-03-02T06:00:00Z"}, {"id": "rec1c682c89f9bc54", "table_id": "tble552937bb02832", "fields": {"company_name": "Denteractive", "website": "denteractive.com", "founded": "2018", "services": "Live video dental consultations, provider network", "pricing": "$49-79/consult", "funding": "Bootstrapped", "notes": "Most similar to what I'd build. Real-time video consults with general dentists. Smaller operation, seems bootstrapped. UI looks dated. Lower price point than Teledentistry.com. Room to differentiate on quality and UX."}, "created_time": "2026-03-16T04:30:00Z", "modified_time": "2026-03-16T05:00:00Z"}, {"id": "recd3d90085644c6a", "table_id": "tblb54bf664daeb86", "fields": {"topic": "CA Telehealth Authorization (B&P Code 2290.5)", "jurisdiction": "California", "requirement": "General telehealth authorization for healthcare providers. Providers may deliver services via telehealth. Patient must give informed consent. Provider must document the encounter same as in-person. Applies to dentistry but Dental Board adds extra requirements on top.", "source": "CA Legislature - leginfo.legislature.ca.gov", "last_updated": "2026-01-20"}, "created_time": "2026-01-21T06:00:00Z", "modified_time": "2026-01-21T06:00:00Z"}, {"id": "rec84ecb9e0221cf1", "table_id": "tblb54bf664daeb86", "fields": {"topic": "HIPAA Compliance for Virtual Consults", "jurisdiction": "Federal", "requirement": "All virtual care platforms must be HIPAA compliant. Business Associate Agreement (BAA) required with video platform vendor. Patient data encrypted in transit and at rest. Cannot use consumer video apps (Zoom, FaceTime, Google Meet) without a signed BAA. Need dedicated telehealth platform.", "source": "HHS.gov - HIPAA telehealth guidance", "last_updated": "2026-01-20"}, "created_time": "2026-01-21T06:05:00Z", "modified_time": "2026-01-21T06:05:00Z"}, {"id": "rece38f23b26c51f0", "table_id": "tblb54bf664daeb86", "fields": {"topic": "CA Dental Board Telehealth Requirements", "jurisdiction": "California", "requirement": "Must have existing dentist-patient relationship OR initial in-person exam before providing telehealth services. Exceptions for emergency consultations only. Must be licensed in CA to treat CA patients virtually. No interstate practice without the other state's license. Standard of care same as in-person.", "source": "Dental Board of California - dbc.ca.gov", "last_updated": "2026-01-20"}, "created_time": "2026-01-21T06:10:00Z", "modified_time": "2026-01-21T06:10:00Z"}, {"id": "rec886efaf952a533", "table_id": "tblb54bf664daeb86", "fields": {"topic": "Informed Consent Requirements", "jurisdiction": "California", "requirement": "Written informed consent required before first virtual visit. Must explain: limitations of virtual exam, patient's right to an in-person visit, how data is stored and protected, fee structure and insurance coverage. Consent must be stored in patient record.", "source": "CA B&P Code 2290.5(b)", "last_updated": "2026-01-20"}, "created_time": "2026-01-21T06:15:00Z", "modified_time": "2026-01-21T06:15:00Z"}, {"id": "reca130adb2451abb", "table_id": "tblb54bf664daeb86", "fields": {"topic": "Insurance and Reimbursement Landscape", "jurisdiction": "California / Federal", "requirement": "Medi-Cal reimburses teledentistry at same rate as in-person since 2022. Private insurers vary. Delta Dental covers synchronous virtual consults. Other carriers may not. CPT codes for synchronous telehealth apply. Must verify each payer's telehealth policy individually. Reimbursement rates for virtual-only generally 10-15% lower than in-person.", "source": "DHCS.ca.gov, ADA coding resources, David Huang summary", "last_updated": "2026-02-01"}, "created_time": "2026-01-21T06:20:00Z", "modified_time": "2026-02-01T23:00:00Z"}, {"id": "rec60c07e378f1998", "table_id": "tbl429225982ec7d5", "fields": {"category": "Startup Costs", "item": "Platform development (HIPAA-compliant video + scheduling)", "amount": 85000, "frequency": "One-time", "notes": "Custom build estimate from 2 dev shops I contacted. Alt: license MouthWatch or Doxy.me platform at $3-5K/yr but less control and customization."}, "created_time": "2026-02-11T07:00:00Z", "modified_time": "2026-02-11T07:00:00Z"}, {"id": "reca0898219e8fb07", "table_id": "tbl429225982ec7d5", "fields": {"category": "Startup Costs", "item": "Security audit and HIPAA compliance setup", "amount": 18000, "frequency": "One-time", "notes": "Penetration testing, compliance consulting, BAA agreements with all vendors. Non-negotiable for healthcare."}, "created_time": "2026-02-11T07:05:00Z", "modified_time": "2026-02-11T07:05:00Z"}, {"id": "rec6fe35c2c662f9c", "table_id": "tbl429225982ec7d5", "fields": {"category": "Startup Costs", "item": "Legal, licensing, business formation", "amount": 10000, "frequency": "One-time", "notes": "Telehealth malpractice rider, state licensing fees, attorney for patient agreements and terms of service. LLC formation."}, "created_time": "2026-02-11T07:10:00Z", "modified_time": "2026-02-11T07:10:00Z"}, {"id": "rec726695c75640e0", "table_id": "tbl429225982ec7d5", "fields": {"category": "Operating", "item": "Monthly operating costs", "amount": 5200, "frequency": "Monthly", "notes": "Cloud hosting $400, malpractice rider $350, marketing $2K, part-time admin $1.5K, software tools $250, phone/internet $200, misc $500."}, "created_time": "2026-02-11T07:15:00Z", "modified_time": "2026-02-16T07:00:00Z"}, {"id": "rec014db4c722f241", "table_id": "tbl429225982ec7d5", "fields": {"category": "Revenue", "item": "Average revenue per virtual consult", "amount": 85, "frequency": "Per consult", "notes": "Insurance reimburses $65-95 for synchronous telehealth dental. Self-pay patients $75-99. Blended average ~$85."}, "created_time": "2026-02-11T07:20:00Z", "modified_time": "2026-02-11T07:20:00Z"}, {"id": "recfc197040b1f83c", "table_id": "tbl429225982ec7d5", "fields": {"category": "Revenue", "item": "Monthly revenue at target volume (25 consults/wk)", "amount": 8500, "frequency": "Monthly", "notes": "25 consults/wk x $85 avg = $8,500/mo. Ramp: Month 1-3 = 5-10/wk, Month 4-6 = 15-20/wk, Month 7+ = 25-30/wk."}, "created_time": "2026-02-11T07:25:00Z", "modified_time": "2026-02-16T07:00:00Z"}, {"id": "rec846399739bd0ce", "table_id": "tbl429225982ec7d5", "fields": {"category": "Summary", "item": "Break-even on operating costs", "amount": 0, "frequency": "Month 7-8", "notes": "Operating break-even when volume hits ~15 consults/wk (~$5,100/mo revenue vs $5,200 costs). Full capital payback around month 18-22."}, "created_time": "2026-02-11T07:30:00Z", "modified_time": "2026-02-16T07:00:00Z"}, {"id": "rec17f93f2176ee6d", "table_id": "tbl429225982ec7d5", "fields": {"category": "Summary", "item": "Total startup capital needed (18-month runway)", "amount": 135000, "frequency": "One-time", "notes": "Platform $85K + compliance $18K + legal $10K + 6mo operating runway $31K = $135K minimum. SBA 7(a) could cover but adds to $185K student loan debt. Thats the problem."}, "created_time": "2026-02-11T07:35:00Z", "modified_time": "2026-02-16T07:00:00Z"}, {"id": "rec5f0b8d2a4c6e97", "table_id": "tbl7d2a4e8c1f5b93", "fields": {"course_name": "Infection Control Fundamentals", "credit_hours": "4", "completion_date": "2026-02-22", "provider": "CDA", "certificate": "CE_Certificate_Infection_Control_Choi.pdf", "status": "Complete"}, "created_time": "2026-02-25T17:30:00Z", "modified_time": "2026-02-25T17:30:00Z"}, {"id": "rec6a1c9e3b5d7f08", "table_id": "tbl7d2a4e8c1f5b93", "fields": {"course_name": "OSHA Update for Dental Professionals", "credit_hours": "4", "completion_date": "2026-02-22", "provider": "CDA", "certificate": "CE_Certificate_OSHA_Update_Choi.pdf", "status": "Complete"}, "created_time": "2026-02-25T17:32:00Z", "modified_time": "2026-02-25T17:32:00Z"}, {"id": "rec7b2d0f4c6e8a19", "table_id": "tbl7d2a4e8c1f5b93", "fields": {"course_name": "Sterilization and Disinfection Protocols", "credit_hours": "4", "completion_date": "2026-02-23", "provider": "CDA", "certificate": "CE_Certificate_Sterilization_Choi.pdf", "status": "Complete"}, "created_time": "2026-02-25T17:34:00Z", "modified_time": "2026-02-25T17:34:00Z"}, {"id": "rec8c3e1a5d7f9b20", "table_id": "tbl7d2a4e8c1f5b93", "fields": {"course_name": "Emergency Preparedness and Office Safety", "credit_hours": "4", "completion_date": "2026-02-23", "provider": "CDA", "certificate": "CE_Certificate_Emergency_Prep_Choi.pdf", "status": "Complete"}, "created_time": "2026-02-25T17:36:00Z", "modified_time": "2026-02-25T17:36:00Z"}, {"id": "rec4e9a2c5f7b1d38", "table_id": "tbl5b0d3f6c8e2a49", "fields": {"date": "2025-01-15", "vendor": "CDA", "category": "Professional Dues", "amount": 600, "payment_method": "Visa 3156", "receipt": "CDA_Membership_2025.pdf", "notes": "Annual CDA membership renewal"}, "created_time": "2026-03-11T05:00:00Z", "modified_time": "2026-03-11T05:00:00Z"}, {"id": "rec5f0b3d6a8c2e49", "table_id": "tbl5b0d3f6c8e2a49", "fields": {"date": "2025-02-14", "vendor": "Henry Schein", "category": "Dental Supplies", "amount": 1847.5, "payment_method": "Visa 3156", "receipt": "HS_Invoice_021425.pdf", "notes": "Composites, bonding agents, impression materials"}, "created_time": "2026-03-11T05:03:00Z", "modified_time": "2026-03-11T05:03:00Z"}, {"id": "rec6a1c4e7b9d3f50", "table_id": "tbl5b0d3f6c8e2a49", "fields": {"date": "2025-03-01", "vendor": "Dentrix", "category": "Software", "amount": 4788, "payment_method": "Visa 3156", "receipt": "Dentrix_Annual_2025.pdf", "notes": "Practice management software annual subscription"}, "created_time": "2026-03-11T05:07:00Z", "modified_time": "2026-03-11T05:07:00Z"}, {"id": "rec7b2d5f8c0e4a61", "table_id": "tbl5b0d3f6c8e2a49", "fields": {"date": "2025-04-22", "vendor": "Patterson Dental", "category": "Equipment Maintenance", "amount": 425, "payment_method": "Checking 4821", "receipt": "Patterson_Autoclave_042225.pdf", "notes": "Autoclave service and inspection"}, "created_time": "2026-03-11T05:10:00Z", "modified_time": "2026-03-11T05:10:00Z"}, {"id": "rec8c3e6a9d1f5b72", "table_id": "tbl5b0d3f6c8e2a49", "fields": {"date": "2025-06-01", "vendor": "TDIC", "category": "Insurance", "amount": 3240, "payment_method": "Checking 4821", "receipt": "TDIC_Premium_2025.pdf", "notes": "Professional liability insurance annual premium"}, "created_time": "2026-03-11T05:15:00Z", "modified_time": "2026-03-11T05:15:00Z"}, {"id": "rec9d4f7b0e2a6c83", "table_id": "tbl5b0d3f6c8e2a49", "fields": {"date": "2025-07-18", "vendor": "Henry Schein", "category": "Dental Supplies", "amount": 2134, "payment_method": "Visa 3156", "receipt": "HS_Invoice_071825.pdf", "notes": "Q3 restock - gloves, masks, prophy paste, fluoride varnish"}, "created_time": "2026-03-11T05:19:00Z", "modified_time": "2026-03-11T05:19:00Z"}, {"id": "rec0e5a8c1f3b7d94", "table_id": "tbl5b0d3f6c8e2a49", "fields": {"date": "2025-09-30", "vendor": "Sacramento Dental Lab", "category": "Lab Fees", "amount": 4680, "payment_method": "Checking 4821", "receipt": "SacDentalLab_Q3_2025.pdf", "notes": "Crown and bridge fabrication - Q3 total"}, "created_time": "2026-03-11T05:23:00Z", "modified_time": "2026-03-11T05:23:00Z"}, {"id": "rec1f6b9d2a4c8e05", "table_id": "tbl5b0d3f6c8e2a49", "fields": {"date": "2025-12-31", "vendor": "Google Ads", "category": "Marketing", "amount": 7200, "payment_method": "Visa 3156", "receipt": "GoogleAds_2025_Summary.pdf", "notes": "Practice marketing - Google Ads annual spend ($600/mo avg)"}, "created_time": "2026-03-11T05:26:00Z", "modified_time": "2026-03-11T05:26:00Z"}]}