id": "2432d075af6c5ae18a4e711847831bab", "ts": "1767603600.000000", "type": "message", "user": "U_RMERCER", "text": "happy new year team \u2014 quick reminder Q4 timesheets are due by EOD friday", "channel": "C_GENERAL", "thread_ts": null, "reply_count": 0, "reply_users_count": 0, "latest_reply": null, "is_activity_message": false, "subtype": null, "reactions": [], "files": [], "attachments": []}, {"id": "999a3b53e1c558309dd2fa5cf32354d6", "ts": "1770820200.000000", "type": "message", "user": "U_RMERCER", "text": "snow day tomorrow per the forecast \u2014 work from home, sync over slack as needed", "channel": "C_GENERAL", "thread_ts": null, "reply_count": 0, "reply_users_count": 0, "latest_reply": null, "is_activity_message": false, "subtype": null, "reactions": [], "files": [], "attachments": []}, {"id": "cc5daa48d0c952e0ac81519aa64357b0", "ts": "1772622900.000000", "type": "message", "user": "U_MDAVIS", "text": "anyone know if the conference room booking system is down again? trying to grab Roosevelt for 2pm", "channel": "C_GENERAL", "thread_ts": null, "reply_count": 0, "reply_users_count": 0, "latest_reply": null, "is_activity_message": false, "subtype": null, "reactions": [], "files": [], "attachments": []}, {"id": "c3b5853352bd5b4692209f7f39329213", "ts": "1775061900.000000", "type": "message", "user": "U_RMERCER", "text": "reminder: spring engagement survey closes friday, please carve out 10 min", "channel": "C_GENERAL", "thread_ts": null, "reply_count": 0, "reply_users_count": 0, "latest_reply": null, "is_activity_message": false, "subtype": null, "reactions": [], "files": [], "attachments": []}, {"id": "e3d70f7b1a0356268574bc88cc380a3f", "ts": "1778493900.000000", "type": "message", "user": "U_MDAVIS", "text": "fyi the printer on 4 is jammed again, IT has been pinged", "channel": "C_GENERAL", "thread_ts": null, "reply_count": 0, "reply_users_count": 0, "latest_reply": null, "is_activity_message": false, "subtype": null, "reactions": [], "files": [], "attachments": []}, {"id": "ba7dced1652258699bf84dde561d8904", "ts": "1768403100.000000", "type": "message", "user": "U_RMERCER", "text": "Good. Plan for a two-week analysis window once everything is in.", "channel": "C_PROJECT_HEALTHCARE", "thread_ts": "1768402800.000000", "reply_count": 0, "reply_users_count": 0, "latest_reply": null, "is_activity_message": false, "subtype": null, "reactions": [], "files": [], "attachments": []}, {"id": "5320124943af51809d7c2c3c35757e8a", "ts": "1769610000.000000", "type": "message", "user": "U_RMERCER", "text": "The Rutland variance is notable. Make sure we quantify the cost impact. I want dollar figures in the final report.", "channel": "C_PROJECT_HEALTHCARE", "thread_ts": "1769609700.000000", "reply_count": 0, "reply_users_count": 0, "latest_reply": null, "is_activity_message": false, "subtype": null, "reactions": [], "files": [], "attachments": []}, {"id": "d83ef3aef6675895b4582997463a2b53", "ts": "1769610600.000000", "type": "message", "user": "U_MDAVIS", "text": "Already on it. Using their average reimbursement rates against bed turnover impact.", "channel": "C_PROJECT_HEALTHCARE", "thread_ts": "1769609700.000000", "reply_count": 0, "reply_users_count": 0, "latest_reply": null, "is_activity_message": false, "subtype": null, "reactions": [], "files": [], "attachments": []}, {"id": "593142b3e804565abc2b9fc10dfc76de", "ts": "1769610900.000000", "type": "message", "user": "U_RMERCER", "text": "Good. Keep me posted on the draft timeline.", "channel": "C_PROJECT_HEALTHCARE", "thread_ts": "1769609700.000000", "reply_count": 0, "reply_users_count": 0, "latest_reply": null, "is_activity_message": false, "subtype": null, "reactions": [], "files": [], "attachments": []}, {"id": "4fd670a00b795a9d94e1538b8b6a092b", "ts": "1770308400.000000", "type": "message", "user": "U_RMERCER", "text": "Received. Will review over the weekend and have comments back to you Monday.", "channel": "C_PROJECT_HEALTHCARE", "thread_ts": "1770308100.000000", "reply_count": 0, "reply_users_count": 0, "latest_reply": null, "is_activity_message": false, "subtype": null, "reactions": [], "files": [], "attachments": []}, {"id": "795de8213c735035baa7f2856f9b66e4", "ts": "1771009500.000000", "type": "message", "user": "U_RMERCER", "text": "Confirmed. Conference Room B. Bring printed copies of the executive summary.", "channel": "C_PROJECT_HEALTHCARE", "thread_ts": "1771009200.000000", "reply_count": 0, "reply_users_count": 0, "latest_reply": null, "is_activity_message": false, "subtype": null, "reactions": [], "files": [], "attachments": []}, {"id": "150be3f0e99c551e90e1eaa27a5a4a1c", "ts": "1771515300.000000", "type": "message", "user": "U_RMERCER", "text": "Good. Make sure the presentation deck pulls directly from the report findings. No surprises.", "channel": "C_PROJECT_HEALTHCARE", "thread_ts": "1771515000.000000", "reply_count": 0, "reply_users_count": 0, "latest_reply": null, "is_activity_message": false, "subtype": null, "reactions": [], "files": [], "attachments": []}, {"id": "1adb68c211e553bc9ab9115afec78d04", "ts": "1772202900.000000", "type": "message", "user": "U_RMERCER", "text": "I will meet you at the GMHN offices at 1:30. Come prepared.", "channel": "C_PROJECT_HEALTHCARE", "thread_ts": "1772202600.000000", "reply_count": 0, "reply_users_count": 0, "latest_reply": null, "is_activity_message": false, "subtype": null, "reactions": [], "files": [], "attachments": []}, {"id": "14c833f1d15f50c7a3eaa911554a66a7", "ts": "1772203200.000000", "type": "message", "user": "U_MDAVIS", "text": "See you there.", "channel": "C_PROJECT_HEALTHCARE", "thread_ts": "1772202600.000000", "reply_count": 0, "reply_users_count": 0, "latest_reply": null, "is_activity_message": false, "subtype": null, "reactions": [], "files": [], "attachments": []}, {"id": "c49f1665065f58ceb804a8d28b17ec94", "ts": "1773436500.000000", "type": "message", "user": "U_RMERCER", "text": "Got it. Thanks for the heads up.", "channel": "C_CONSULTING_TEAM", "thread_ts": "1773435600.000000", "reply_count": 0, "reply_users_count": 0, "latest_reply": null, "is_activity_message": false, "subtype": null, "reactions": [], "files": [], "attachments": []}, {"id": "df38b2e060d0542cb2579aeb58f58a8d", "ts": "1777036620.000000", "type": "message", "user": "U_RMERCER", "text": "Get the proposal to me by 4. Make sure the financials section is current.", "channel": "C_CONSULTING_TEAM", "thread_ts": "1777036500.000000", "reply_count": 0, "reply_users_count": 0, "latest_reply": null, "is_activity_message": false, "subtype": null, "reactions": [], "files": [], "attachments": []}, {"id": "2c181ad5e68959d39a4ac3cbc0652961", "ts": "1777731300.000000", "type": "message", "user": "U_RMERCER", "text": "Caught the fourth quarter. Impressive finish.", "channel": "C_RANDOM", "thread_ts": "1777730400.000000", "reply_count": 0, "reply_users_count": 0, "latest_reply": null, "is_activity_message": false, "subtype": null, "reactions": [], "files": [], "attachments": []}, {"id": "8d124843ea9a5b68a2b878386a76a104", "ts": "1777731480.000000", "type": "message", "user": "U_MDAVIS", "text": "yeah they're rolling right now", "channel": "C_RANDOM", "thread_ts": "1777730400.000000", "reply_count": 0, "reply_users_count": 0, "latest_reply": null, "is_activity_message": false, "subtype": null, "reactions": [], "files": [], "attachments": []}]}